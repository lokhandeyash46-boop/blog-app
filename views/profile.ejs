<section class="wrap auth-wrap">
  <div class="auth-card">
    <p class="eyebrow">Your account</p>
    <h1 class="auth-title">Profile</h1>

    <% if (success) { %>
      <p class="flash flash-success">Profile updated.</p>
    <% } %>

    <% if (errors && errors.length) { %>
      <ul class="form-errors">
        <% errors.forEach(function(e) { %><li><%= e %></li><% }) %>
      </ul>
    <% } %>

    <form action="/profile?_method=PUT" method="POST" class="form">
      <label for="name">Name</label>
      <input type="text" id="name" name="name" value="<%= currentUser.name %>" required maxlength="60" />

      <label>Email</label>
      <input type="email" value="<%= currentUser.email %>" disabled />

      <label for="bio">Bio</label>
      <textarea id="bio" name="bio" rows="3" maxlength="280"><%= currentUser.bio %></textarea>

      <label>Role</label>
      <input type="text" value="<%= currentUser.role %>" disabled />

      <button type="submit" class="btn btn-full">Save profile</button>
    </form>
  </div>
</section>
