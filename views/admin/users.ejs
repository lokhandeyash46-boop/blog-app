<section class="wrap">
  <p class="eyebrow">Admin</p>
  <h1 class="page-title">Manage users</h1>

  <table class="post-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Role</th>
        <th>Joined</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(function(u) { %>
        <tr>
          <td><%= u.name %></td>
          <td><%= u.email %></td>
          <td><span class="badge badge-<%= u.role === 'admin' ? 'published' : 'draft' %>"><%= u.role %></span></td>
          <td><%= new Date(u.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
          <td>
            <form action="/admin/users/<%= u._id %>/role?_method=PUT" method="POST" class="inline-form">
              <select name="role" onchange="this.form.submit()">
                <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>user</option>
                <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>admin</option>
              </select>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>
