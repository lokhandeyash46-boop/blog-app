<article class="wrap post-view">
  <p class="eyebrow"><%= post.category %></p>
  <h1 class="post-view-title"><%= post.title %></h1>
  <p class="post-view-meta">
    By <strong><%= post.author.name %></strong>
    &middot;
    <%= post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : 'Draft' %>
    &middot;
    <%= post.views %> views
  </p>

  <% if (post.status === 'draft') { %>
    <p class="badge badge-draft">Draft — only visible to you and admins</p>
  <% } %>

  <div class="post-view-body">
    <% post.content.split('\n').filter(function(p){ return p.trim().length; }).forEach(function(paragraph) { %>
      <p><%= paragraph %></p>
    <% }) %>
  </div>

  <% if (post.tags && post.tags.length) { %>
    <div class="tag-row">
      <% post.tags.forEach(function(tag) { %>
        <span class="tag">#<%= tag %></span>
      <% }) %>
    </div>
  <% } %>

  <% if (locals.currentUser && (currentUser.role === 'admin' || currentUser._id.equals(post.author._id))) { %>
    <div class="post-owner-actions">
      <a href="/posts/<%= post._id %>/edit" class="btn btn-small btn-outline">Edit post</a>
      <form action="/posts/<%= post._id %>?_method=DELETE" method="POST" class="inline-form"
            onsubmit="return confirm('Delete this post? This cannot be undone.');">
        <button type="submit" class="btn btn-small btn-danger">Delete</button>
      </form>
    </div>
  <% } %>

  <% if (post.author.bio) { %>
    <div class="author-card">
      <p class="author-card-name"><%= post.author.name %></p>
      <p class="author-card-bio"><%= post.author.bio %></p>
    </div>
  <% } %>
</article>

<% if (related && related.length) { %>
  <section class="wrap related-section">
    <h2 class="section-heading">More in <%= post.category %></h2>
    <div class="post-grid">
      <% related.forEach(function(r) { %>
        <article class="post-card">
          <a href="/<%= r.slug %>" class="post-card-link">
            <h3 class="post-card-title"><%= r.title %></h3>
            <p class="post-card-excerpt"><%= r.excerpt %></p>
          </a>
        </article>
      <% }) %>
    </div>
  </section>
<% } %>
